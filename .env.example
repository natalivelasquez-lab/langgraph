AZURE_OPENAI_ENDPOINT=https://<tu-recurso>.openai.azure.com/
AZURE_OPENAI_API_KEY=<tu-api-key>
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

OPENAI_API_KEY=sk-...
OPENAI_IMAGE_MODEL=gpt-4o

PUBLIC_BASE_URL=http://localhost:8000

# Tool SQL
# Ejemplo SQLite:
# SQL_DATABASE_URL=sqlite:///./examples/sql/demo.db
# Ejemplo Postgres:
# SQL_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/demo
SQL_DATABASE_URL=
SQL_SCHEMA_CSV_PATH=examples/sql/company_schema.csv
# Opcional: si quieres usar otro deployment para generar SQL
AZURE_OPENAI_SQL_DEPLOYMENT=
